            {
              "count": 10,
              "itemCategory": "general",
              "lengthSpecLower": 1.5,
              "productCategoryCode": "PC1",
              "qualityGrade": "A",
              "quantity": 12.5,
              "thicknessSpecLower": 0.5,
              "thicknessSpecUpper": 1.2
            }
          ],
          "division": {
            "code": 10,
            "name": "名称"
          },
