            "code": 10,
            "name": "名称"
          },
          "processCategory": {
            "code": 10,
            "name": "名称"
          },
          "section": {
            "code": 10,
            "name": "名称"
          },
          "status": "manufacturing",
          "version": 1
        },
        "headers": {
          "Content-Type": "application/json"
        },
        "matchingRules": {
          "body": {
            "$.department.code": {
              "combine": "AND",
              "matchers": [
                {
                  "match": "integer"
                }
              ]
            },
