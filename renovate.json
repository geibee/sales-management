{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
    ":dependencyDashboard"
  ],
  "schedule": [
    "before 6am on monday"
  ],
  "vulnerabilityAlerts": {
    "enabled": true,
    "labels": ["security"]
  },
  "packageRules": [
    {
      "description": "patch / minor は automerge",
      "matchUpdateTypes": ["patch", "minor"],
      "automerge": true
    },
    {
      "description": "major は手動レビュー",
      "matchUpdateTypes": ["major"],
      "automerge": false
    }
  ]
}
