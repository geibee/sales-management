    <Compile Include="Domain/LotWorkflows.fs" />
    <Compile Include="Domain/SalesCaseWorkflows.fs" />
    <Compile Include="Domain/ReservationCaseWorkflows.fs" />
    <Compile Include="Domain/ConsignmentCaseWorkflows.fs" />
    <Compile Include="Infrastructure/LotRepository.fs" />
    <Compile Include="Infrastructure/LotListRepository.fs" />
    <Compile Include="Infrastructure/SalesCaseRepository.fs" />
    <Compile Include="Infrastructure/SalesCaseListRepository.fs" />
    <Compile Include="Infrastructure/AppraisalRepository.fs" />
    <Compile Include="Infrastructure/ReservationPriceRepository.fs" />
    <Compile Include="Infrastructure/ConsignmentRepository.fs" />
    <Compile Include="Infrastructure/ExternalPricingClient.fs" />
    <Compile Include="Infrastructure/OutboxRepository.fs" />
    <Compile Include="Infrastructure/OutboxProcessor.fs" />
    <Compile Include="Api/ProblemDetails.fs" />
    <Compile Include="Api/LotDtos.fs" />
    <Compile Include="Api/Auth.fs" />
    <Compile Include="Api/HealthChecks.fs" />
    <Compile Include="Api/LotCsvExport.fs" />
    <Compile Include="Infrastructure/ChunkProgressRepository.fs" />
    <Compile Include="Infrastructure/BatchProcessing.fs" />
    <Compile Include="Infrastructure/JobExecutionRepository.fs" />
    <Compile Include="Infrastructure/MonthlyCloseBatch.fs" />
    <Compile Include="Infrastructure/PartitionedBatch.fs" />
    <Compile Include="Infrastructure/CloudWatchPublisher.fs" />
    <Compile Include="Infrastructure/MonitoringBatch.fs" />
    <Compile Include="Infrastructure/CsvImportBatch.fs" />
    <Compile Include="Api/LotListRoutes.fs" />
    <Compile Include="Api/LotRoutes.fs" />
    <Compile Include="Api/SalesCaseDtos.fs" />
    <Compile Include="Api/ReservationCaseDtos.fs" />
    <Compile Include="Api/ConsignmentCaseDtos.fs" />
    <Compile Include="Api/SalesCaseDetailRoutes.fs" />
    <Compile Include="Api/SalesCaseRoutes.fs" />
    <Compile Include="Api/ReservationCaseRoutes.fs" />
