{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Database": {
    "ConnectionString": "Host=localhost;Port=5432;Database=sales_management;Username=app;Password=app"
  },
  "Server": {
    "Port": 5000
  },
  "Authentication": {
    "Enabled": false,
    "Authority": "http://localhost:8180/realms/sales-management",
    "Audience": "sales-api",
    "RequireHttpsMetadata": false
  },
  "ExternalApi": {
    "PricingUrl": "http://localhost:8181",
    "TimeoutMs": 3000,
    "RetryCount": 3,
    "CircuitFailures": 5
  },
  "RateLimit": {
    "PermitLimit": 100,
    "WindowSeconds": 60
  },
  "Cors": {
    "AllowedOrigins": ["http://localhost:5173"]
  },
  "Hosting": {
    "ShutdownTimeoutSeconds": 30
  },
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.Hosting.Lifetime": "Information"
      }
    }
  }
}
