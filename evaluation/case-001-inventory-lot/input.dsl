// ============================================================
// 在庫ロット領域（dsl/domain-model.md の該当部分を切り出し）
// ============================================================

// ----------------------------------------------------------------
// 基本値型
// ----------------------------------------------------------------

// 事業部コード
data 事業部コード = 整数

// 部門コード
data 部門コード = 整数

// 担当課コード
data 担当課コード = 整数

// ロット番号（年度・保管場所・連番の組み合わせで一意）
data ロット番号 = ロット番号年度 AND ロット番号保管場所 AND ロット番号連番

// 0以上、円単位
data 金額 = 整数

// 0.001以上
data 数量 = 数値

// 1以上
data 個数 = 整数

// ----------------------------------------------------------------
// ロット明細（在庫ロットの構成要素）
// ----------------------------------------------------------------

data ロット明細 = 品目区分
    AND 上位品区分?
    AND 商品分類コード
    AND 長さ規格下限
    AND 太さ規格下限
    AND 太さ規格上限
    AND 品質等級
    AND 個数
    AND 数量
    AND 検査結果区分?

// 一般品・上位品・特注品のいずれか
data 品目区分 = 一般品 OR 上位品 OR 特注品

// ----------------------------------------------------------------
// 在庫ロット（最小管理単位）
// ----------------------------------------------------------------

// 在庫ロットは製造の進捗に応じて状態が変わる
data 在庫ロット = 製造中ロット OR 製造完了ロット OR 変換指示済みロット OR 出荷指示済みロット OR 出荷完了ロット

data ロット共通 = ロット番号
    AND 事業部コード
    AND 部門コード
    AND 担当課コード
    AND 工程区分
    AND 検査区分
    AND 製造区分
    AND List<ロット明細> // 1件以上

// 工程区分：検査・製造・出荷等の工程の区分
data 工程区分 = 整数

// 検査区分：検査済み・未検査など
data 検査区分 = 整数

// 製造区分：製造方法の区分
data 製造区分 = 整数

data 製造中ロット = ロット共通

data 製造完了ロット = ロット共通
    AND 製造完了日

data 出荷指示済みロット = ロット共通
    AND 製造完了日
    AND 出荷期限日

data 出荷完了ロット = ロット共通
    AND 製造完了日
    AND 出荷期限日
    AND 出荷日

// 品目変換が指示された状態のロット
data 変換指示済みロット = ロット共通
    AND 製造完了日
    AND 変換先情報

// ----------------------------------------------------------------
// 振る舞い
// ----------------------------------------------------------------

// 在庫ロットのライフサイクル
behavior 製造完了を指示する = 製造中ロット AND 製造完了日 -> 製造完了ロット OR 製造完了指示エラー
behavior 出荷を指示する = 製造完了ロット AND 出荷期限日 -> 出荷指示済みロット OR 出荷指示エラー
behavior 出荷完了を指示する = 出荷指示済みロット AND 出荷日 -> 出荷完了ロット OR 出荷完了指示エラー
behavior 製造完了を取り消す = 製造完了ロット -> 製造中ロット OR 取消エラー

// 品目変換（ロットの品目区分変換）
behavior 品目変換を指示する = 製造完了ロット AND 変換先情報 -> 変換指示済みロット OR 変換指示エラー
behavior 品目変換指示を取り消す = 変換指示済みロット -> 製造完了ロット OR 変換指示取消エラー
