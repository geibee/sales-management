// ============================================================
// 価格査定 + 販売契約 領域（dsl/domain-model.md の該当部分を切り出し）
// ============================================================

// ----------------------------------------------------------------
// 識別子
// ----------------------------------------------------------------

// 査定番号（年度・月度・連番の組み合わせで一意）
data 査定番号 = 査定番号年度 AND 査定番号月度 AND 査定番号連番

// 契約番号（年度・月度・連番の組み合わせで一意）
data 契約番号 = 契約番号年度 AND 契約番号月度 AND 契約番号連番

// ----------------------------------------------------------------
// 価格査定（販売案件に値段をつける）
// ----------------------------------------------------------------

// 査定方式によって必要な情報が異なる
data 価格査定 = 通常査定 OR 顧客契約査定

data 査定共通 = 査定番号
    AND 査定日
    AND 納期
    AND 販売市場
    AND 基準単価適用日
    AND 期間調整率適用日
    AND 取引先調整率適用日
    AND 税抜予定総額
    AND List<ロット価格査定> // 1件以上

data 通常査定 = 査定共通

// 顧客契約査定は大口顧客との年間契約に基づく
data 顧客契約査定 = 査定共通
    AND 顧客契約番号
    AND 契約調整率

// ロットごとの価格査定情報
data ロット価格査定 = ロット番号
    AND 加工費?
    AND 個別受注加算?
    AND 等級加算?
    AND 予約加算?
    AND 調整率?
    AND 品質調整率?
    AND 製造費単価?
    AND 想定販売期間?
    AND 目標利益率?
    AND List<ロット明細価格査定> // 1件以上

// ロット明細ごとの価格査定情報
data ロット明細価格査定 = ロット明細
    AND 基準単価
    AND 期間調整率
    AND 取引先調整率
    AND 特例期間調整率?

// 予約価格は確定前後で不変条件が変わる
data 予約価格 = 暫定予約価格 OR 確定予約価格

data 予約価格共通 = 査定番号
    AND 査定日
    AND 予約対象ロット情報
    AND 予約金額

data 暫定予約価格 = 予約価格共通

data 確定予約価格 = 予約価格共通
    AND 確定日
    AND 確定金額

// ----------------------------------------------------------------
// 販売契約（査定に基づき締結する契約）
// ----------------------------------------------------------------

data 販売契約 = 契約番号
    AND 契約日
    AND 担当者
    AND 購入者
    AND 販売情報
    AND 販売価格情報
    AND 査定番号 // 紐づく価格査定

data 購入者 = 顧客番号
    AND 代理人氏名?

data 販売情報 = 販売種別
    AND 品目
    AND 納入方法
    AND 支払猶予条件?
    AND 販売方式
    AND 用途?
    AND 支払猶予金額?

// 販売方式：直販・代理店経由・契約販売など
data 販売方式 = 整数

// 販売種別：一般品・上位品・特注品など
data 販売種別 = 整数

data 販売価格情報 = 税抜契約金額
    AND 消費税額
    AND 税抜入金額
    AND 入金消費税額

// ----------------------------------------------------------------
// 振る舞い
// ----------------------------------------------------------------

// 価格査定のライフサイクル
behavior 価格査定を作成する = 査定前直接販売案件 AND 査定情報 -> 査定済み直接販売案件 OR 査定作成エラー
behavior 価格査定を更新する = 査定済み直接販売案件 AND 査定情報 -> 査定済み直接販売案件 OR 査定更新エラー
behavior 価格査定を削除する = 査定済み直接販売案件 -> 査定前直接販売案件 OR 査定削除エラー

// 販売契約のライフサイクル
behavior 販売契約を締結する = 査定済み直接販売案件 AND 契約情報 -> 契約済み直接販売案件 OR 契約締結エラー
behavior 販売契約を削除する = 契約済み直接販売案件 -> 査定済み直接販売案件 OR 契約削除エラー
