(* ============================================================
   Sales Management DSL Grammar (EBNF / ISO 14977 風)
   ============================================================

   このファイルは DSL の文法のみを定義する（意味論は SEMANTICS.md）。

   表記:
     =       定義
     |       選択
     { ... } 0回以上の繰り返し
     [ ... ] 0または1回（オプショナル）
     ( ... ) グルーピング
     "..."   リテラル
     ?...?   メタ識別子（人間向けの注釈）

   ============================================================
   レイヤー構成（重要）
   ------------------------------------------------------------
   DSL は 2 層に分かれる:

     [CORE]         ドメインエキスパートが読み書きする層。
                    型構造と振る舞いシグネチャだけ。
                    格納先: dsl/domain-model.md

     [VERIFICATION] 技術者が書き、AI が Alloy / TLA+ 等に翻訳する層。
                    値域制約・事前事後条件・不変条件・時相性質。
                    格納先: dsl/verification.md（P4 で導入）

   各章の見出しに [CORE] / [VERIFICATION] / [SHARED] を付ける。
   [SHARED] は両層で使われる述語・式・字句のサブ言語。

   現在の P1 パーサーが受理すべきは [CORE] のみ。
   ============================================================

   コア層サブセット（P1 実装スコープ）
   ------------------------------------------------------------
     §1 dataDecl      （where/unit/description 句を除く）
     §2 behaviorDecl  （requires/ensures/error_when 句を除く）
     §8 字句

   検証層（P4 実装スコープ）
   ------------------------------------------------------------
     §1 の where/unit/description 句
     §2 の requires/ensures/error_when 句
     §3 invariantDecl
     §4 propertyDecl
     §5 initialDecl
     §6 述語サブ言語
     §7 式サブ言語
   ============================================================ *)


(* === トップレベル === *)

program         = { declaration } ;

declaration     = dataDecl                  (* [CORE]         *)
                | behaviorDecl              (* [CORE]         *)
                | invariantDecl             (* [VERIFICATION] *)
                | propertyDecl              (* [VERIFICATION] *)
                | initialDecl ;             (* [VERIFICATION] *)


(* ============================================================
   1. データ宣言
   ------------------------------------------------------------
   [CORE]         dataDecl の本体（identifier "=" dataExpr）
   [VERIFICATION] whereClause / unitClause / descriptionClause

   コア例:
       data 在庫ロット = 製造中ロット OR 製造完了ロット
       data ロット共通 = ロット番号 AND 事業部コード AND List<ロット明細>
       data ロット明細 = 品目区分 AND 上位品区分? AND ...

   検証層を含む例（P4）:
       data 金額 = 整数 where 値 >= 0 unit 円
       data ロット共通 = ... AND List<ロット明細> { length >= 1 }
   ============================================================ *)

dataDecl        = "data" identifier "=" dataExpr            (* [CORE] *)
                  [ whereClause ]                           (* [VERIFICATION] *)
                  [ unitClause ]                            (* [VERIFICATION] *)
                  [ descriptionClause ] ;                   (* [VERIFICATION] *)

(* --- [CORE] データ式 --- *)

dataExpr        = sumExpr ;
sumExpr         = productExpr { "OR" productExpr } ;
productExpr     = atomType  { "AND" atomType  } ;

atomType        = optionalType
                | listType
                | identifier
                | "(" dataExpr ")" ;

optionalType    = identifier "?" ;
listType        = "List" "<" identifier ">" [ cardinality ] ;

(* 注: 現行 DSL（dsl/domain-model.md）は "List<X> // 1件以上" のような
       コメントでカーディナリティを表現している。コメントはトークン化時に
       スキップされ、文法的にはカーディナリティなしの listType として扱う。
       明示構文 "{ length >= 1 }" は [VERIFICATION] 拡張で P4 で導入予定。 *)

cardinality     = "{" "length" comparator integer "}" ;     (* [VERIFICATION] *)

(* --- [VERIFICATION] データ宣言の付加句 --- *)

whereClause     = "where" predicate ;                       (* [VERIFICATION] *)
unitClause      = "unit" identifier ;                       (* [VERIFICATION] *)
descriptionClause = "description" stringLit ;               (* [VERIFICATION] *)


(* ============================================================
   2. 振る舞い宣言
   ------------------------------------------------------------
   [CORE]         behaviorDecl の本体（シグネチャまで）
   [VERIFICATION] requires / ensures / error_when 句

   コア例:
       behavior 製造完了を指示する = 製造中ロット AND 製造完了日
                                  -> 製造完了ロット OR 製造完了指示エラー

   検証層を含む例（P4）:
       behavior 製造完了を指示する = 製造中ロット AND 製造完了日
                                  -> 製造完了ロット OR 製造完了指示エラー
           requires 製造完了日 >= 製造開始日
           ensures result.ロット番号 == input.ロット番号
           error_when 製造完了日 < 製造開始日 -> 日付不正エラー

   注: 区切りは "=" を用いる（dsl/domain-model.md の記法に合わせる）。
   ============================================================ *)

behaviorDecl    = "behavior" identifier "="                    (* [CORE] *)
                  productExpr "->" productExpr "OR" identifier (* [CORE] *)
                  { requireClause }                            (* [VERIFICATION] *)
                  { ensureClause }                             (* [VERIFICATION] *)
                  { errorClause }                              (* [VERIFICATION] *)
                  [ descriptionClause ] ;                      (* [VERIFICATION] *)

(* 注: 入出力は productExpr に限定する（OR は最後の "OR <error>" 用に予約）。
       OR を含む状態の引き渡しは現 DSL では出現しないため、この制限で十分。 *)

requireClause   = "requires" predicate ;                    (* [VERIFICATION] *)
ensureClause    = "ensures" predicate ;                     (* [VERIFICATION] *)
errorClause     = "error_when" predicate "->" identifier ;  (* [VERIFICATION] *)


(* ============================================================
   3. 横断的不変条件                              [VERIFICATION]
   ------------------------------------------------------------
   例: invariant ロット番号一意性:
         forall l1, l2 in 在庫ロット.
           l1.ロット番号 == l2.ロット番号 => l1 == l2
   ============================================================ *)

invariantDecl   = "invariant" identifier ":" predicate ;


(* ============================================================
   4. 時相的性質                                  [VERIFICATION]
   ------------------------------------------------------------
   例: property liveness:
         forall c in 契約済み直接販売案件.
           c.状態 == 契約済み ~> c.状態 == 出荷完了
   ============================================================ *)

propertyDecl    = "property" identifier ":" temporalPredicate ;

temporalPredicate = "always" predicate
                  | "eventually" predicate
                  | predicate "~>" predicate         (* "leads to" *)
                  | predicate ;


(* ============================================================
   5. 初期状態                                    [VERIFICATION]
   ------------------------------------------------------------
   例: initial:
         在庫ロット = {}
         販売案件 = {}
   ============================================================ *)

initialDecl     = "initial" ":" { stateAssignment } ;
stateAssignment = identifier "=" valueExpr ;


(* ============================================================
   6. 述語サブ言語                                    [SHARED]
   ------------------------------------------------------------
   where / requires / ensures / error_when / invariant /
   property の中身として使われる。
   コア層では使用されない。
   ============================================================ *)

predicate       = implication ;
implication     = orPred [ "=>" orPred ] ;
orPred          = andPred { "||" andPred } ;
andPred         = notPred { "&&" notPred } ;
notPred         = [ "!" ] atomicPred ;

atomicPred      = quantified
                | comparison
                | functionCall
                | "(" predicate ")"
                | "true"
                | "false" ;

quantified      = quantifier identifier { "," identifier } "in" identifier "." predicate ;
quantifier      = "forall" | "exists" ;

comparison      = expr comparator expr ;
comparator      = "==" | "!=" | "<" | "<=" | ">" | ">=" ;


(* ============================================================
   7. 式サブ言語                                      [SHARED]
   ------------------------------------------------------------
   述語サブ言語と initialDecl から参照される。
   コア層では使用されない。
   ============================================================ *)

expr            = orExpr ;
orExpr          = andExpr { "||" andExpr } ;
andExpr         = addExpr { "&&" addExpr } ;
addExpr         = mulExpr { ("+" | "-") mulExpr } ;
mulExpr         = atomExpr { ("*" | "/") atomExpr } ;

atomExpr        = literal
                | fieldAccess
                | functionCall
                | aggregation
                | "(" expr ")" ;

fieldAccess     = identifier { "." identifier } ;
functionCall    = identifier "(" [ exprList ] ")" ;
aggregation     = ("sum" | "count" | "min" | "max") "(" expr "for" identifier "in" expr ")" ;
exprList        = expr { "," expr } ;

valueExpr       = literal | fieldAccess | "{" "}" ;
literal         = integer | stringLit | "true" | "false" ;


(* ============================================================
   8. 字句要素                                        [SHARED]
   ============================================================ *)

identifier      = ( letter | japaneseChar | "_" )
                  { letter | digit | japaneseChar | "_" } ;

integer         = digit { digit } ;
stringLit       = '"' { ?any character except "?  } '"' ;

letter          = "a" | ... | "z" | "A" | ... | "Z" ;
digit           = "0" | ... | "9" ;
japaneseChar    = ?Unicode 範囲 U+3000-U+9FFF, U+30A0-U+30FF, U+3040-U+309F? ;

(* コメントとホワイトスペースはトークン化時にスキップする *)
comment         = "//" { ?any character? } newline ;
whitespace      = " " | "\t" | "\n" | "\r" ;
